# Environment Configuration for TheraQuest v2
# Copy this file to .env and fill in your values

# ─── REQUIRED ────────────────────────────────────────────────────
# Groq API Key — Get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── OPTIONAL: Supabase (Session Persistence) ────────────────────
# Create a free project at https://supabase.com
# Run supabase_schema.sql in your Supabase SQL editor first
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# ─── OPTIONAL: Nimble (Live Web Search — Agent 4) ────────────────
# Get your key at https://nimbleway.com
NIMBLE_API_KEY=your_nimble_api_key_here

# ─── APP CONFIG ──────────────────────────────────────────────────
BACKEND_PORT=8000
ENVIRONMENT=development
